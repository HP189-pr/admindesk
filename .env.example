# Frontend environment template

# Shared values in .env
# VITE_PUBLIC_BUILDER_KEY=your_builder_public_key

# Copy this block to .env.development
# Development: frontend http://localhost:3000 -> backend http://127.0.0.1:8001
VITE_API_BASE_URL=http://127.0.0.1:8001
VITE_MEDIA_BASE_URL=http://127.0.0.1:8001
VITE_WS_BASE_URL=http://127.0.0.1:8001

# Copy this block to .env.production
# Production: frontend http://localhost:8081 -> backend http://127.0.0.1:8000
# VITE_API_BASE_URL=http://127.0.0.1:8000
# VITE_MEDIA_BASE_URL=http://127.0.0.1:8000
# VITE_WS_BASE_URL=http://127.0.0.1:8000
